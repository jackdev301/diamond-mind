# diamond-mind environment configuration
# Copy to .env and fill in the keys you have. Missing keys must NOT cause
# crashes — clients should stub gracefully and the report should flag the gap.

# --- Database -----------------------------------------------------------------
# SQLite for local MVP; swap for a postgresql:// URL in production.
DATABASE_URL=sqlite:///./diamond_mind.db

# --- External data sources ----------------------------------------------------
# MLB Stats API is public and keyless; override the base URL only if needed.
MLB_STATS_API_BASE=https://statsapi.mlb.com/api/v1

# The Odds API (https://the-odds-api.com). Leave blank to disable odds ingestion.
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4

# Weather. Open-Meteo is keyless; OpenWeather requires a key.
WEATHER_PROVIDER=open-meteo
OPENWEATHER_API_KEY=

# --- Obsidian -----------------------------------------------------------------
# Path to the local Obsidian vault. Defaults to the in-repo vault used for dev.
OBSIDIAN_VAULT_PATH=./obsidian_vault

# --- LLM (Phase 12, optional) -------------------------------------------------
ANTHROPIC_API_KEY=

# --- Runtime ------------------------------------------------------------------
LOG_LEVEL=INFO
